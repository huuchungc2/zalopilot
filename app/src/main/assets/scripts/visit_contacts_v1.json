{
  "id": "visit_contacts_v1",
  "version": 12,
  "desc": "Visit v12 — CHAT_ONLY gửi tin khung chat; profile like/comment khi không chat",
  "steps": [
    { "id": "s1", "action": "findContactItems" },
    { "id": "s2", "action": "tapContactAt" },
    { "id": "s3", "action": "wait", "ms": 1200 },
    { "id": "s3a", "action": "ifSetting", "key": "visitActionChat", "do": [
      { "action": "ensureScreen", "screen": "chat", "timeoutMs": 5000 },
      { "action": "repeat", "count": "$visitChatCount", "do": [
        { "action": "sendVisitChatMessage" }
      ]}
    ]},
    { "id": "s4", "action": "ifSetting", "key": "visitActionProfile", "do": [
      { "action": "tapProfileEntry" },
      { "action": "wait", "ms": 3500 },
      { "action": "likeProfilePosts", "count": "$visitLikeCount" },
      { "action": "ifSetting", "key": "visitCommentCount", "gt": 0, "do": [
        { "action": "repeat", "count": "$visitCommentCount", "do": [
          { "action": "findCommentButton" },
          { "action": "tap" },
          { "action": "ensureScreen", "screen": "comments", "timeoutMs": 4000 },
          { "action": "inputRandomComment" },
          { "action": "tapSend" },
          { "action": "back" }
        ]}
      ]}
    ]},
    { "id": "s8", "action": "openContactsFriends" },
    { "id": "s9", "action": "scrollContacts" },
    { "id": "s10", "action": "incrementVar", "var": "$visitIndex" },
    { "id": "s11", "action": "saveVar", "var": "$visitIndex" },
    { "id": "s12", "action": "goto", "step": "s1" }
  ]
}
